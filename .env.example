# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MALIFY — Ortam Değişkenleri
#  Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
#  ÖNEMLİ: .env dosyasını asla git'e commit etmeyin!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Uygulama
APP_NAME="Malify Backend"
APP_VERSION="0.1.0"
DEBUG=true

# Sunucu
HOST=0.0.0.0
PORT=8000

# Veritabanı (SQLite — geliştirme)
DATABASE_URL=sqlite+aiosqlite:///./malify.db

# PDF Depolama
PDF_STORAGE_DIR=storage/pdfs

# AI Servis (OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Resmî Gazete
GAZETTE_BASE_URL=https://www.resmigazete.gov.tr

# Zamanlama — her sabah saat kaçta çekilsin (24 saat, UTC)
GAZETTE_SCRAPE_HOUR=6
GAZETTE_SCRAPE_MINUTE=0
