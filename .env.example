# ──────────────── Uygulama ────────────────
APP_NAME=Malify Backend
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ──────────────── Veritabanı ────────────────
# SQLite (geliştirme)
DATABASE_URL=sqlite:///./malify.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/malify

# ──────────────── AI ────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ──────────────── Scraping ────────────────
SCRAPE_BASE_URL=https://www.resmigazete.gov.tr
SCRAPE_DELAY_SECONDS=1.5

# ──────────────── CORS ────────────────
# Virgülle ayırarak birden fazla origin ekleyebilirsin
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
